EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
# Web OAuth client (type "Web application") from Google Cloud > Credentials, same project as Firebase.
# Fix redirect_uri_mismatch: in that client, add both Authorized JS origins and Authorized redirect URIs,
# e.g. http://localhost:8081 and http://127.0.0.1:8081 (match the host you use in the browser).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional: force redirect to match Google (if you only registered one, e.g. http://127.0.0.1:8081)
# EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT=
