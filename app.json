{
  "expo": {
    "name": "Discipline Goals",
    "slug": "decipline-goals",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "decipline-goals",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "Discipline Goals",
      "shortName": "Goals",
      "description": "Daily goals, discipline, and wellness tracking.",
      "backgroundColor": "#ffffff",
      "themeColor": "#18181b",
      "display": "standalone",
      "startUrl": "/",
      "lang": "en",
      "output": "single"
    },
    "plugins": ["expo-web-browser"]
  }
}
